---

const socialLinks = [
	{ label: 'GitHub', href: 'https://github.com/dltvn', icon: 'github' },
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/in/denys-lytvyn-6b6aab362/', icon: 'linkedin' },
	{ label: 'Email', href: 'mailto:denysltvn@gmail.com', icon: 'email' },
];

const navLinks = [
	{ label: 'home', href: '#home' },
	{ label: 'about me', href: '#about' },
	{ label: 'timeline', href: '#timeline' },
	{ label: 'projects', href: '#projects' },
	{ label: 'blog', href: '#blog' },
];
---

<div class="page-shell">
	<header class="site-header">
		<div class="logo logo-availability" aria-label="Available">
			<span class="availability-dot" aria-hidden="true"></span>
			<span class="availability-label">Available</span>
		</div>
		<nav class="site-nav" aria-label="Primary">
			{
				navLinks.map((link) => (
					<a href={link.href}>
						{link.label}
					</a>
				))
			}
		</nav>
		<a class="resume-button" href="/resume.pdf" download>
			Get my resume
		</a>
	</header>

	<main id="top" class="page-main">
		<slot />
	</main>

	<footer class="site-footer">
		<p class="copyright">© 2026 Denys Lytvyn</p>
		<nav class="footer-nav" aria-label="Footer">
			{
				navLinks.map((link) => (
					<a href={link.href}>
						{link.label}
					</a>
				))
			}
		</nav>
	</footer>

	<div class="social-dock" data-social-dock>
		<div class="social-links" id="social-links" aria-label="Social links">
			{
				socialLinks.map((social) => (
					<a class="social-link" href={social.href} aria-label={social.label}>
						{social.icon === 'github' && (
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path
									fill="currentColor"
									d="M12 2C6.477 2 2 6.59 2 12.253c0 4.53 2.865 8.373 6.839 9.73.5.096.682-.222.682-.494 0-.244-.009-.89-.014-1.748-2.782.618-3.369-1.37-3.369-1.37-.455-1.177-1.11-1.49-1.11-1.49-.908-.637.069-.625.069-.625 1.003.072 1.53 1.054 1.53 1.054.892 1.563 2.341 1.111 2.91.849.091-.667.35-1.111.636-1.367-2.22-.258-4.555-1.137-4.555-5.062 0-1.118.39-2.033 1.029-2.75-.103-.259-.446-1.298.098-2.706 0 0 .84-.276 2.75 1.05A9.303 9.303 0 0 1 12 6.84a9.27 9.27 0 0 1 2.504.348c1.909-1.326 2.748-1.05 2.748-1.05.546 1.408.203 2.447.1 2.706.64.717 1.027 1.632 1.027 2.75 0 3.935-2.339 4.801-4.566 5.054.359.318.679.944.679 1.903 0 1.375-.012 2.484-.012 2.822 0 .274.18.594.688.493A10.262 10.262 0 0 0 22 12.253C22 6.59 17.523 2 12 2Z"
								/>
							</svg>
						)}
						{social.icon === 'linkedin' && (
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path
									fill="currentColor"
									d="M4.983 3.5C4.983 4.881 3.87 6 2.498 6A2.5 2.5 0 0 1 0 3.5C0 2.119 1.113 1 2.498 1a2.5 2.5 0 0 1 2.485 2.5ZM.5 8h4v15h-4V8Zm6.5 0h3.833v2.047h.055c.534-1.014 1.84-2.084 3.787-2.084C18.707 7.963 21 10.14 21 14.234V23h-4v-7.734c0-1.845-.033-4.219-2.568-4.219-2.57 0-2.964 2.008-2.964 4.086V23h-4V8Z"
								/>
							</svg>
						)}
						{social.icon === 'email' && (
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path
									fill="currentColor"
									d="M2 5.5A2.5 2.5 0 0 1 4.5 3h15A2.5 2.5 0 0 1 22 5.5v13a2.5 2.5 0 0 1-2.5 2.5h-15A2.5 2.5 0 0 1 2 18.5v-13Zm2.64-.5L12 10.547 19.36 5H4.64ZM20 6.2l-7.398 5.572a1 1 0 0 1-1.204 0L4 6.2v12.3a.5.5 0 0 0 .5.5h15a.5.5 0 0 0 .5-.5V6.2Z"
								/>
							</svg>
						)}
					</a>
				))
			}
		</div>
	</div>
</div>

<script>
	const socialDock = document.querySelector('[data-social-dock]');
	const siteFooter = document.querySelector('.site-footer');
	const animatedHeadings = document.querySelectorAll('.top-heading');

	if (socialDock instanceof HTMLElement) {
		if (siteFooter instanceof HTMLElement) {
			const observer = new IntersectionObserver(
				([entry]) => {
					socialDock.dataset.hidden = entry?.isIntersecting ? 'true' : 'false';
				},
				{ threshold: 0.01 },
			);

			observer.observe(siteFooter);
		}
	}

	for (const heading of animatedHeadings) {
		const replayJiggle = () => {
			heading.classList.remove('is-jiggling');
			void heading.offsetWidth;
			heading.classList.add('is-jiggling');
		};

		heading.addEventListener('mouseenter', replayJiggle);
		heading.addEventListener('focus', replayJiggle);
	}

	const replayTargetHeading = () => {
		const targetHeading = document.querySelector('.section:target .top-heading');
		if (targetHeading instanceof HTMLElement) {
			targetHeading.classList.remove('is-jiggling');
			void targetHeading.offsetWidth;
			targetHeading.classList.add('is-jiggling');
		}
	};

	window.addEventListener('hashchange', replayTargetHeading);
	replayTargetHeading();
</script>

<style>
	.page-shell {
		--header-height: 92px;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	main {
		flex: 1;
	}

	.page-main {
		display: flex;
		flex-direction: column;
		padding-top: var(--header-height);
	}

	.site-header,
	.site-footer {
		background: var(--surface-frame);
		color: var(--text-dark);
		display: grid;
		align-items: center;
		padding: 20px 28px;
	}

	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 20;
		min-height: var(--header-height);
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		gap: 20px;
	}

	.site-footer {
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 24px;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		font-family: 'Satoshi', Arial, sans-serif;
		font-size: 1rem;
		font-weight: 400;
		letter-spacing: -0.01em;
		line-height: 1;
		text-decoration: none;
		text-transform: lowercase;
	}

	.availability-dot {
		width: 12px;
		height: 12px;
		border-radius: 999px;
		background: var(--highlight);
		transform-origin: center;
		animation: availability-fade 1.4s var(--ease-out) infinite;
	}

	.availability-label {
		display: inline-block;
		text-transform: capitalize;
	}

	@keyframes availability-fade {
		0% {
			opacity: 1;
			transform: scale(1);
		}

		50% {
			opacity: 0.22;
			transform: scale(0.82);
		}

		100% {
			opacity: 1;
			transform: scale(1);
		}
	}

	.site-nav,
	.footer-nav {
		display: flex;
		gap: 24px;
		justify-content: center;
		flex-wrap: wrap;
	}

	.site-nav a,
	.footer-nav a,
	.resume-button {
		position: relative;
		display: inline-block;
		font-size: 1rem;
		text-transform: capitalize;
		text-decoration: none;
	}

	.site-nav a:hover,
	.site-nav a:focus-visible,
	.footer-nav a:hover,
	.footer-nav a:focus-visible {
		text-decoration: none;
	}

	.site-nav a::after,
	.footer-nav a::after,
	.resume-button::after {
		content: '';
		position: absolute;
		left: 50%;
		bottom: -0.18em;
		width: 100%;
		height: 1px;
		background: currentColor;
		opacity: 0;
		transform: translateX(-50%) scaleX(0);
		transform-origin: center;
		transition:
			opacity 220ms var(--ease-out),
			transform 220ms var(--ease-out);
	}

	.site-nav a:hover::after,
	.site-nav a:focus-visible::after,
	.footer-nav a:hover::after,
	.footer-nav a:focus-visible::after,
	.resume-button:hover::after,
	.resume-button:focus-visible::after {
		opacity: 1;
		transform: translateX(-50%) scaleX(1);
	}

	@media (prefers-reduced-motion: reduce) {
		.site-nav a::after,
		.footer-nav a::after,
		.resume-button::after {
			transition:
				opacity 220ms var(--ease-out),
				transform 220ms var(--ease-out) !important;
		}
	}

	.resume-button {
		justify-self: end;
		background: transparent;
		color: var(--text-dark);
		border: 0;
		padding: 0;
		transition: color 180ms var(--ease-out);
	}

	.resume-button:hover,
	.resume-button:focus-visible,
	.site-nav a:hover,
	.site-nav a:focus-visible,
	.footer-nav a:hover,
	.footer-nav a:focus-visible {
		color: currentColor;
	}

	.resume-button:focus-visible,
	.site-nav a:focus-visible,
	.footer-nav a:focus-visible,
	.social-link:focus-visible {
		outline: 2px solid currentColor;
		outline-offset: 4px;
	}

	:global(.page-shell .section) {
		padding: 0 28px;
		scroll-margin-top: var(--header-height);
	}

	:global(.page-shell .section-inner) {
		padding: clamp(36px, 6vw, 88px) 0;
		width: min(100%, 1120px);
		margin: 0 auto;
	}

	h1,
	h2,
	h3,
	p {
		margin: 0;
	}

	:global(.page-shell .top-heading) {
		--heading-tilt: -4deg;
		font-family: 'Satoshi', Arial, sans-serif;
		font-weight: 400;
		line-height: 1;
		letter-spacing: -0.02em;
		display: inline-block;
		background: var(--highlight);
		color: var(--text-dark);
		padding: 0.04em 0.16em 0.1em;
		box-decoration-break: clone;
		-webkit-box-decoration-break: clone;
		text-transform: uppercase;
		text-align: center;
		transform: rotate(-4deg);
	}

	:global(.page-shell .top-heading.is-jiggling) {
		animation: top-heading-jiggle 420ms var(--ease-out);
	}

	:global(.page-shell .top-heading.on-light) {
		--heading-tilt: 4deg;
		background: var(--text-dark);
		color: var(--text-light);
		transform: rotate(4deg);
	}

	@keyframes top-heading-jiggle {
		0% {
			transform: rotate(var(--heading-tilt, -4deg)) translateX(0);
		}

		25% {
			transform: rotate(calc(var(--heading-tilt, -4deg) - 3deg)) translateX(-2px);
		}

		50% {
			transform: rotate(calc(var(--heading-tilt, -4deg) + 2deg)) translateX(2px);
		}

		75% {
			transform: rotate(calc(var(--heading-tilt, -4deg) - 1deg)) translateX(-1px);
		}

		100% {
			transform: rotate(var(--heading-tilt, -4deg)) translateX(0);
		}
	}

	:global(.page-shell h1.top-heading) {
		font-size: clamp(3rem, 7vw, 5.6rem);
	}

	:global(.page-shell h2.top-heading) {
		font-size: clamp(3rem, 7vw, 5.6rem);
		margin-bottom: 0;
	}

	:global(.page-shell h3) {
		font-size: clamp(1.2rem, 2vw, 1.65rem);
		font-weight: 500;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	p,
	li {
		font-size: 1.125rem;
		line-height: 1.68;
		letter-spacing: -0.01em;
	}

	.copyright {
		justify-self: start;
		font-size: 0.95rem;
		letter-spacing: 0.08em;
		text-transform: lowercase;
		color: rgba(18, 18, 18, 0.7);
	}

	.social-links {
		position: relative;
		right: auto;
		bottom: 0;
		display: flex;
		gap: 12px;
		align-items: center;
		will-change: transform, opacity;
		transition:
			opacity 220ms var(--ease-out),
			transform 220ms var(--ease-out);
		transform-origin: center center;
	}

	.footer-nav {
		justify-content: flex-end;
	}

	.social-dock {
		position: fixed;
		right: 18px;
		bottom: 18px;
		display: flex;
		justify-content: flex-end;
		align-items: center;
		height: 52px;
		z-index: 25;
		transition:
			opacity 180ms var(--ease-out),
			transform 180ms var(--ease-out);
	}

	.social-dock[data-hidden='true'] {
		opacity: 0;
		transform: translateX(16px);
		pointer-events: none;
	}

	.social-link {
		width: 52px;
		height: 52px;
		border-radius: 999px;
		background: var(--surface-dark);
		color: var(--text-light);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(249, 249, 249, 0.16);
		transition:
			transform 220ms var(--ease-out),
			background-color 180ms var(--ease-out),
			color 180ms var(--ease-out);
	}

	.social-link:hover,
	.social-link:focus-visible {
		background: var(--highlight);
		color: var(--text-dark);
		transform: translateY(-3px) rotate(-6deg) scale(1.06);
	}

	.social-link svg {
		width: 20px;
		height: 20px;
		transition: transform 220ms var(--ease-out);
	}

	.social-link:hover svg,
	.social-link:focus-visible svg {
		transform: scale(1.08);
	}

	@media (prefers-reduced-motion: reduce) {
		:global(.page-shell .top-heading) {
			transition: transform 220ms var(--ease-out) !important;
		}

		.social-links,
		.social-link,
		.social-link svg {
			transition:
				transform 220ms var(--ease-out),
				background-color 180ms var(--ease-out),
				color 180ms var(--ease-out) !important;
		}
	}

	@media (max-width: 960px) {
		.page-shell {
			--header-height: 132px;
		}

		.site-header,
		.site-footer {
			grid-template-columns: 1fr;
		}

		.site-nav,
		.footer-nav {
			justify-content: flex-start;
		}

		.resume-button {
			justify-self: start;
		}
	}

	@media (max-width: 720px) {
		.page-shell {
			--header-height: 156px;
		}

		.site-header,
		.site-footer,
		:global(.page-shell .section) {
			padding-left: 16px;
			padding-right: 16px;
		}

		.social-dock {
			flex-direction: column;
			align-items: flex-end;
			height: auto;
		}

		.social-links {
			flex-direction: column;
		}
	}
</style>
