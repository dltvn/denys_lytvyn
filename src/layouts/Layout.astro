	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	::selection {
		background: var(--highlight);
		color: var(--text-dark);
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
